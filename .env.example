# ── Frontend / API ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
APP_NAME=Yantronix Scraper API
ALLOWED_ORIGINS=http://localhost:3000

# ── Google Gemini API ────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.3
GEMINI_MAX_OUTPUT_TOKENS=12000
MAX_RAW_TEXT_CHARS=12000

# ── MongoDB ──────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/
MONGO_DB_NAME=scraper_db

# ── Redis / Celery ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Rate limits ──────────────────────────────────────────────
RATE_LIMIT_EXTRACT_PER_MINUTE=10
RATE_LIMIT_GENERATE_PER_MINUTE=5
RATE_LIMIT_PUBLISH_PER_MINUTE=3
RATE_LIMIT_AI_CALLS_PER_HOUR=20
SCRAPE_TIMEOUT_SECONDS=15
MIN_SCRAPED_TEXT_CHARS=100

# ── Application Modes ────────────────────────────────────────
# Set to 'false' to enable live publishing to Zoho Commerce.
TEST_MODE=true

# ── Zoho Commerce OAuth (Self Client) ────────────────────────
ZOHO_CLIENT_ID=your_client_id_here
ZOHO_CLIENT_SECRET=your_client_secret_here
ZOHO_ORGANIZATION_ID=your_org_id_here

# Zoho Accounts Base URL based on your datacenter:
#   India    -> https://accounts.zoho.in
#   US/Other -> https://accounts.zoho.com
ZOHO_ACCOUNTS_URL=https://accounts.zoho.in

# Zoho Commerce API Domain:
#   India    -> https://commerce.zoho.in
#   US/Other -> https://commerce.zoho.com
ZOHO_API_DOMAIN=https://commerce.zoho.in

# Refresh token generated from Zoho's initial OAuth flow.
ZOHO_REFRESH_TOKEN=your_refresh_token_here
