# ── Google Gemini API ────────────────────────────────────────
# Get your API key from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here

# ── MongoDB ──────────────────────────────────────────────────
# Default settings for local MongoDB instance
MONGO_URI=mongodb://localhost:27017/
MONGO_DB_NAME=scraper_db

# ── Application Modes ────────────────────────────────────────
# Set to 'false' to enable live publishing to Zoho Commerce
TEST_MODE=true

# ── Zoho Commerce OAuth (Self Client) ────────────────────────
# From Zoho API Console -> Self Client
ZOHO_CLIENT_ID=your_client_id_here
ZOHO_CLIENT_SECRET=your_client_secret_here

# Found in: Commerce Admin -> Settings -> Organization Details
ZOHO_ORGANIZATION_ID=your_org_id_here

# Zoho Accounts Base URL based on your datacenter:
#   India    -> https://accounts.zoho.in
#   US/Other -> https://accounts.zoho.com
ZOHO_ACCOUNTS_URL=https://accounts.zoho.in

# Zoho Commerce API Domain:
#   India    -> https://commerce.zoho.in
#   US/Other -> https://commerce.zoho.com
ZOHO_API_DOMAIN=https://commerce.zoho.in

# ── Zoho Tokens (Obtained via initial auth flow) ─────────────
# The system will automatically refresh the access token using this refresh token
ZOHO_REFRESH_TOKEN=your_refresh_token_here
