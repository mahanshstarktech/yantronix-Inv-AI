# ── Frontend / API ───────────────────────────────────────────
APP_NAME="Yantronix Scraper API"
ALLOWED_ORIGINS=https://yantronix-inv-ai.pages.dev,http://localhost:8081

# ── Google Gemini API ────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash-lite
GEMINI_TEMPERATURE=0.3
GEMINI_MAX_OUTPUT_TOKENS=12000
MAX_RAW_TEXT_CHARS=12000

# ── MongoDB ──────────────────────────────────────────────────
# On Railway: use the MongoDB plugin's ${{MongoDB.MONGO_URL}} variable
MONGO_URI=mongodb://localhost:27017/
MONGO_DB_NAME=scraper_db

# ── Redis / Celery ───────────────────────────────────────────
# On Railway: use the Redis plugin's ${{Redis.REDIS_URL}} variable
REDIS_URL=redis://localhost:6379/0

# ── Rate limits ──────────────────────────────────────────────
RATE_LIMIT_EXTRACT_PER_MINUTE=10
RATE_LIMIT_GENERATE_PER_MINUTE=5
RATE_LIMIT_PUBLISH_PER_MINUTE=3
RATE_LIMIT_AI_CALLS_PER_HOUR=20
SCRAPE_TIMEOUT_SECONDS=15
MIN_SCRAPED_TEXT_CHARS=100

# ── Application Modes ────────────────────────────────────────
TEST_MODE=false

# ── Zoho Commerce OAuth ───────────────────────────────────────
ZOHO_CLIENT_ID=your-client-id
ZOHO_CLIENT_SECRET=your-client-secret
ZOHO_ORGANIZATION_ID=your-org-id
ZOHO_ACCOUNTS_URL=https://accounts.zoho.in
ZOHO_API_DOMAIN=https://commerce.zoho.in
ZOHO_STORE_DOMAIN=yourstore.zohostore.com
ZOHO_REFRESH_TOKEN=your-refresh-token
